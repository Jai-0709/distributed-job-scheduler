{
  "name": "relay",
  "version": "1.0.0",
  "description": "Distributed background job infrastructure backed by Postgres and Redis",
  "author": "Relay Engineering",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "dev:api": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "dev:scheduler": "ts-node-dev --respawn --transpile-only src/scheduler/index.ts",
    "build": "tsc --project tsconfig.json",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:api": "jest tests/api",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "marked": "^18.0.5",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
